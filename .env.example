# PostgreSQL connection (provided by Coolify managed DB)
DATABASE_URL=postgresql://user:password@host:5432/galaxy_pos

# JWT secret — generate a strong random string for production
JWT_SECRET=change-me-in-production-use-a-long-random-string

# Server port
PORT=7456

# CORS origin — your frontend URL
CORS_ORIGIN=https://pos.yourdomain.com
